class Solution:
    def checkInclusion(self, s1: str, s2: str) -> bool:
        ds =sorted(list(s1))
        ls = list(s2)
        count = 0
        for i in range(0,len(ls)-len(ds)+1):
            k = ls[i:i+len(ds)]
            print(k)
            if ds == sorted(k):
                count = 1
            else:
                continue
        if count ==1:
            return True
        else:
            return False
